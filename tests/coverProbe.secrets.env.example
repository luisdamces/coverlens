# ── Uso ────────────────────────────────────────────────────────────────────
#  cp tests/coverProbe.secrets.env.example tests/coverProbe.secrets.env
#  Rellena solo coverProbe.secrets.env (no subas secretos al .example ni a git).
#
# Orden de trabajo sugerido:
#   1) Comprueba qué devuelve SteamGridDB (sin tocar código de la app):
#        npm run probe:covers:steam
#      (o comenta todas las líneas SCREENSCRAPER_* y npm run probe:covers)
#   2) Cuando tengas devid ScreenScraper, descomenta SS y:
#        npm run probe:covers
#   3) Si los resultados te convencen más con otro orden de fuentes, entonces
#      se cambia coverPreferenceResolver (y se añaden tests).
#
# ScreenScraper — dev: https://www.screenscraper.fr/devzone.php — foro API:
#   https://www.screenscraper.fr/forumsujets.php?frub=12&numpage=0

STEAMGRIDDB_API_KEY=

SCREENSCRAPER_USER=
SCREENSCRAPER_PASSWORD=

SCREENSCRAPER_DEV_ID=
SCREENSCRAPER_DEV_PASSWORD=

# PROBE_TITLE=Gears of War
# PROBE_PLATFORM=Xbox 360
